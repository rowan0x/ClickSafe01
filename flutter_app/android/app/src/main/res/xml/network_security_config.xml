<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for ClickSafe
    ══════════════════════════════════════
    • Production (HTTPS) backends: always allowed — no config needed.
    • Local development (HTTP) backends on localhost / 10.0.2.2 (Android
      emulator alias for the host machine): cleartext explicitly allowed
      so you can point the Settings screen at http://localhost:5000 or
      http://10.0.2.2:5000 while developing.
    • All other cleartext HTTP is BLOCKED for security.
-->
<network-security-config>
    <!-- Allow cleartext for local dev backends only -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>

    <!-- Everything else: HTTPS only -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
