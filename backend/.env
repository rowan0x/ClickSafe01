# =============================================================================
# backend/.env.example — copy to .env and fill in real values
# =============================================================================
#   cp .env.example .env
# NEVER commit .env to source control — it is in .gitignore.
# =============================================================================

# ── Flask / Server ────────────────────────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use "*" for local dev only.
ALLOWED_ORIGINS=*

# ── Intel Loop API Key ────────────────────────────────────────────────────────
# Must match X-Intel-Key header sent by the Flutter app's Settings screen.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTEL_API_KEY=7dcf227ace6b588615ddf0cedbdc91754430b845d68e7881b1b4bc0635c45e1f

# ── Google Safe Browsing v4 (Real-Time Blocklist) ─────────────────────────────
# Free key — 10,000 lookups/day. Get one at:
#   https://developers.google.com/safe-browsing/v4/get-started
# Leave empty to disable blocklist lookups (heuristics+ML still run).
GOOGLE_SAFE_BROWSING_KEY=

# ── ML Model ──────────────────────────────────────────────────────────────────
# If absent, server starts in heuristic-only mode (ML-01 failsafe).
# Regenerate: python train_model.py
MODEL_PATH=models/model.pkl

# ── Tranco Whitelist ──────────────────────────────────────────────────────────
# CSV format: rank,domain  — download from https://tranco-list.eu/
# Falls back to 37-domain hardcoded set when absent.
TRANCO_PATH=data/tranco.csv
